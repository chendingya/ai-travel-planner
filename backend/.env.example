# ============================================
# 服务器配置
# ============================================
PORT=3010
HOST=127.0.0.1
NODE_ENV=development

# ============================================
# Supabase 配置
# ============================================
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# 文本生成提供商配置 (按优先级顺序)
# ============================================
AI_TEXT_PROVIDERS_JSON='[
  {
    "name": "mcp-provider",
    "baseURL": "https://api-inference.modelscope.cn/v1",
    "apiKey": "",
    "models": [
      {
        "model": "deepseek-ai/DeepSeek-V3.2",
        "priority": 3
      },
      {
        "model": "ZhipuAI/GLM-5",
        "priority": 1
      },
      {
        "model": "Qwen/Qwen3-VL-235B-A22B-Instruct",
        "priority": 2
      }
    ]
  },
  {
    "name": "non-mcp-provider",
    "baseURL": "https://api-ai.gitcode.com/v1",
    "apiKey": "",
    "models": [
      {
        "model": "deepseek-ai/DeepSeek-V3.2",
        "priority": 11
      },
      {
        "model": "moonshotai/Kimi-K2-Thinking",
        "priority": 12
      },
      {
        "model": "zai-org/GLM-4.7",
        "priority": 13
      }
    ]
  }
]'
AI_TEXT_PROVIDER_MCP_PRIMARY=mcp-provider
AI_TEXT_PROVIDER_DEFAULT_PRIMARY=non-mcp-provider

# 提供商配置落库加密密钥（32字节，支持明文32字符或base64后32字节）
PROVIDER_CONFIG_ENCRYPTION_KEY=replace_with_32_byte_key
# 供应商debug模式
PROVIDER_CONFIG_DEBUG=0

# ============================================
# 图片生成提供商配置 (按优先级顺序)
# ============================================
AI_IMAGE_PROVIDERS_JSON='[
  {
    "name": "modelscope",
    "baseURL": "https://api-inference.modelscope.cn/v1",
    "apiKey": "your_modelscope_api_key",
    "model": "Tongyi-MAI/Z-Image-Turbo",
    "priority": 1
  }
]'

# ============================================
# 高德地图配置（前端需要）
# ============================================
AMAP_KEY=your_amap_key
AMAP_SECURITY_CODE=your_amap_security_code
AMAP_REST_KEY=your_amap_rest_key
# 本地 AMap MCP npm 包使用
AMAP_MAPS_API_KEY=your_amap_rest_key

# ============================================
# RAG 知识库 Embedding 配置（ModelScope / Qwen3-Embedding）
# ModelScope Token 申请：https://modelscope.cn/my/myaccesstoken
# ============================================
# ModelScope API Key
QWEN_EMBEDDING_API_KEY=ms-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Embedding 接入点（默认 ModelScope；如用 DashScope 改为 https://dashscope.aliyuncs.com/compatible-mode/v1）
QWEN_EMBEDDING_BASE_URL=https://api-inference.modelscope.cn/v1
# Embedding 模型（Qwen3-Embedding-8B 支持 Matryoshka 截断，可通过 dimensions 参数控制输出维度）
QWEN_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# 向量维度（需与 rag-setup.sql 中 VECTOR(N) 保持一致；Qwen3-Embedding-8B 原生 4096，可截断到 1024）
QWEN_EMBEDDING_DIM=1024
# 本地 embedding 模型目录（供 scripts/ingest_local_qwen.py、scripts/test_rag_local_qwen.py 使用）
QWEN_EMBEDDING_MODEL_PATH=../../Qwen/Qwen3-Embedding-4B
# 本地 reranker 模型目录（供 scripts/test_rag_local_qwen.py 使用）
QWEN_RERANKER_MODEL_PATH=../../Qwen/Qwen3-Reranker-4B
# 本地知识库 JSONL 文件路径（必须是 .jsonl）
RAG_KNOWLEDGE_FILE=../../knowledge_20260306_004228_filtered.jsonl
# 共享知识库标识：开发者之间迁移时保持稳定即可复用同一套数据
RAG_KB_SLUG=travel-cn-public
# 当前导入的数据版本标签，建议与 knowledge_xxx_filtered.jsonl 文件名保持一致
RAG_DATASET_VERSION=20260306_004228
# RAG 检索开关：true 启用，false 关闭（默认 true，配置了 key 才生效）
RAG_ENABLED=true
# 每次检索返回的最大片段数（建议 3~8，越多 token 消耗越高）
RAG_TOP_K=5
# 相似度阈值（0~1，低于此值的片段被丢弃，建议 0.3~0.5）
RAG_SIMILARITY_THRESHOLD=0.35
# Dense 召回候选数
RAG_DENSE_TOP_K=20
# Sparse 召回候选数
RAG_SPARSE_TOP_K=20
# RRF 融合后保留候选数
RAG_RRF_TOP_K=30
# RRF rank 常量
RAG_RRF_K=60
# Sparse 阈值
RAG_SPARSE_THRESHOLD=0.05
# 意图词典缓存分页大小与缓存时长
RAG_INTENT_CATALOG_PAGE_SIZE=1000
RAG_INTENT_CATALOG_TTL_MS=600000

# ============================================
# RAG Rerank 配置（可选，可接本地或线上 HTTP API）
# ============================================
# 是否启用 Rerank（true/false，默认 false；需同时填写 RERANK_BASE_URL 才生效）
RERANK_ENABLED=false
# Rerank 服务地址（可以是本地地址，也可以是线上 API 地址）
RERANK_BASE_URL=http://localhost:8001
# Rerank 路径
RERANK_PATH=/rerank
# Rerank 模型名（传给 API 的 model 字段，部分服务不需要可忽略）
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# 可选：线上 API Token
RERANK_API_KEY=
# 向量初检倍数：先召回 topK × N 个候选，再 Rerank 精选 topK 条（建议 3~5）
RERANK_CANDIDATE_FACTOR=3
# Rerank 调用超时（毫秒）
RERANK_TIMEOUT_MS=10000

# ============================================
# RAG MCP 服务配置
# ============================================
# 后端会把混合 RAG 检索暴露为标准 MCP Streamable HTTP 端点：POST /mcp
RAG_MCP_SERVER_NAME=ai-travel-planner-rag
RAG_MCP_SERVER_VERSION=1.0.0
# true 时强制返回 JSON Response Mode；适合简单 MCP 客户端接入
RAG_MCP_ENABLE_JSON_RESPONSE=true
# 可选：给 MCP 端点加 Bearer Token
RAG_MCP_AUTH_TOKEN=

# ============================================
# CORS 配置
# ============================================
CORS_ORIGIN=*

# ============================================
# Auth Cookie（HttpOnly）配置
# ============================================
# 访问令牌 cookie 名称
AUTH_ACCESS_COOKIE_NAME=sb-access-token
# 刷新令牌 cookie 名称
AUTH_REFRESH_COOKIE_NAME=sb-refresh-token
# strict / lax / none（跨站需 none 且 secure=true）
AUTH_COOKIE_SAMESITE=lax
# 生产环境建议 true；本地 http 调试需 false
AUTH_COOKIE_SECURE=false
# 可选：指定 cookie domain（留空表示当前域）
AUTH_COOKIE_DOMAIN=
# 可选：cookie path
AUTH_COOKIE_PATH=/
# 可选：是否隐藏登录响应中的 session（1=true，推荐保持 1）
AUTH_HIDE_SESSION_IN_RESPONSE=1

# ============================================
# TTS 配置（Piper 本地中文语音）
# ============================================
TTS_PROVIDER=piper
# 容器内 piper 可执行文件；默认安装到 PATH
TTS_PIPER_BIN=piper
# 中文模型路径（可在 Docker 构建时通过 PIPER_MODEL_URL 下载到该位置）
TTS_PIPER_MODEL=/app/runtime/piper/model.onnx
# 可选：模型配置文件路径（通常是 .onnx.json）
TTS_PIPER_CONFIG=/app/runtime/piper/model.onnx.json
# 可选：容器启动时自动下载模型（适合 ModelScope 这类单容器部署）
# TTS_PIPER_MODEL_URL=https://<your-model-url>.onnx
# TTS_PIPER_CONFIG_URL=https://<your-model-url>.onnx.json
# 可选：当 URL 指向 huggingface.co 且下载失败时自动切换镜像域名
# TTS_PIPER_MIRROR_HOST=hf-mirror.com
# 可选：多说话人模型时指定 speaker id
# TTS_PIPER_SPEAKER=0
# 可选：语速和停顿微调
# TTS_PIPER_LENGTH_SCALE=1.0
# TTS_PIPER_SENTENCE_SILENCE=0.15

# prompt调试开关
IMAGE_LOG_PROMPT=true
AI_CHAT_DEBUG=1

# ============================================
# MCP 配置
# ============================================
# 方案 A：本地 npm MCP（推荐）
MCP_SERVERS_JSON='{
  "12306-mcp": {
    "transport": "stdio",
    "command": "node",
    "args": ["./node_modules/12306-mcp/build/index.js"]
  },
  "amap-maps": {
    "transport": "stdio",
    "command": "node",
    "args": ["./node_modules/@amap/amap-maps-mcp-server/build/index.js"]
  },
  "bing-cn-mcp-server": {
    "transport": "stdio",
    "command": "node",
    "args": ["./node_modules/bing-cn-mcp/build/index.js"]
  }
}'

# 方案 B：远端 MCP（如需）
# MCP_12306_URL=https://mcp.api-inference.modelscope.net/xxx/mcp
# MCP_12306_TOKEN=<token>
# MCP_AMAP_URL= https://mcp.api-inference.modelscope.net/xxx/mcp
# MCP_AMAP_AUTHORIZATION=<token>
# MCP_BING_URL=https://mcp.api-inference.modelscope.net/xxx/mcp
# MCP_BING_TOKEN=<token>

# agent最多循环次数
AI_CHAT_AGENT_MAX_ITERATIONS=5
AI_CHAT_AGENT_RECURSION_LIMIT=120
AI_CHAT_MODEL_HTTP_TIMEOUT_MS=120000

# 最大耗时（毫秒）
AI_PLAN_TIMEOUT_MS=240000
AI_PLAN_MODEL_TIMEOUT_MS=60000
AI_PLAN_MAX_TOOL_CALLS=10

# tts相关本地模型配置
TTS_PROVIDER=piper
TTS_PIPER_MODEL=/app/runtime/piper/model.onnx
TTS_PIPER_CONFIG=/app/runtime/piper/model.onnx.json
TTS_PIPER_MODEL_URL=https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/zh/zh_CN/huayan/x_low/zh_CN-huayan-x_low.onnx
TTS_PIPER_CONFIG_URL=https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/zh/zh_CN/huayan/x_low/zh_CN-huayan-x_low.onnx.json
TTS_PIPER_MIRROR_HOST=hf-mirror.com

NODE_BASE=docker.m.daocloud.io/library/node:18-bookworm-slim
