# ============================================
# 服务器配置
# ============================================
PORT=3002
HOST=0.0.0.0
NODE_ENV=development

# ============================================
# Supabase 配置
# ============================================
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# 文本生成提供商配置 (按优先级顺序)
# ============================================
AI_TEXT_PROVIDERS_JSON='[
  {
    "name": "mcp-provider",
    "baseURL": "https://api-inference.modelscope.cn/v1",
    "apiKey": "",
    "models": [
      {
        "model": "deepseek-ai/DeepSeek-V3.2",
        "priority": 3
      },
      {
        "model": "ZhipuAI/GLM-5",
        "priority": 1
      },
      {
        "model": "Qwen/Qwen3-VL-235B-A22B-Instruct",
        "priority": 2
      }
    ]
  },
  {
    "name": "non-mcp-provider",
    "baseURL": "https://api-ai.gitcode.com/v1",
    "apiKey": "",
    "models": [
      {
        "model": "deepseek-ai/DeepSeek-V3.2",
        "priority": 11
      },
      {
        "model": "moonshotai/Kimi-K2-Thinking",
        "priority": 12
      },
      {
        "model": "zai-org/GLM-4.7",
        "priority": 13
      }
    ]
  }
]'
AI_TEXT_PROVIDER_MCP_PRIMARY=mcp-provider
AI_TEXT_PROVIDER_DEFAULT_PRIMARY=non-mcp-provider


# ============================================
# 图片生成提供商配置 (按优先级顺序)
# ============================================
AI_IMAGE_PROVIDERS_JSON='[
  {
    "name": "modelscope",
    "baseURL": "https://api-inference.modelscope.cn/v1",
    "apiKey": "your_modelscope_api_key",
    "model": "Tongyi-MAI/Z-Image-Turbo",
    "priority": 1
  }
]'

# ============================================
# 高德地图配置（前端需要）
# ============================================
AMAP_KEY=your_amap_key
AMAP_SECURITY_CODE=your_amap_security_code
AMAP_REST_KEY=your_amap_rest_key
# 本地 AMap MCP npm 包使用
AMAP_MAPS_API_KEY=your_amap_rest_key

# ============================================
# CORS 配置
# ============================================
CORS_ORIGIN=*

# ============================================
# TTS 配置（Piper 本地中文语音）
# ============================================
TTS_PROVIDER=piper
# 容器内 piper 可执行文件；默认安装到 PATH
TTS_PIPER_BIN=piper
# 中文模型路径（可在 Docker 构建时通过 PIPER_MODEL_URL 下载到该位置）
TTS_PIPER_MODEL=/app/runtime/piper/model.onnx
# 可选：模型配置文件路径（通常是 .onnx.json）
TTS_PIPER_CONFIG=/app/runtime/piper/model.onnx.json
# 可选：容器启动时自动下载模型（适合 ModelScope 这类单容器部署）
# TTS_PIPER_MODEL_URL=https://<your-model-url>.onnx
# TTS_PIPER_CONFIG_URL=https://<your-model-url>.onnx.json
# 可选：当 URL 指向 huggingface.co 且下载失败时自动切换镜像域名
# TTS_PIPER_MIRROR_HOST=hf-mirror.com
# 可选：多说话人模型时指定 speaker id
# TTS_PIPER_SPEAKER=0
# 可选：语速和停顿微调
# TTS_PIPER_LENGTH_SCALE=1.0
# TTS_PIPER_SENTENCE_SILENCE=0.15

# prompt调试开关
IMAGE_LOG_PROMPT=true
AI_CHAT_DEBUG=1

# ============================================
# MCP 配置
# ============================================
# 方案 A：本地 npm MCP（推荐）
MCP_SERVERS_JSON='{
  "12306-mcp": {
    "transport": "stdio",
    "command": "node",
    "args": ["./node_modules/12306-mcp/build/index.js"]
  },
  "amap-maps": {
    "transport": "stdio",
    "command": "node",
    "args": ["./node_modules/@amap/amap-maps-mcp-server/build/index.js"]
  },
  "bing-cn-mcp-server": {
    "transport": "stdio",
    "command": "node",
    "args": ["./node_modules/bing-cn-mcp/build/index.js"]
  }
}'

# 方案 B：远端 MCP（如需）
# MCP_12306_URL=https://mcp.api-inference.modelscope.net/xxx/mcp
# MCP_12306_TOKEN=<token>
# MCP_AMAP_URL= https://mcp.api-inference.modelscope.net/xxx/mcp
# MCP_AMAP_AUTHORIZATION=<token>
# MCP_BING_URL=https://mcp.api-inference.modelscope.net/xxx/mcp
# MCP_BING_TOKEN=<token>

# agent最多循环次数
AI_CHAT_AGENT_MAX_ITERATIONS=5
AI_CHAT_AGENT_RECURSION_LIMIT=120
AI_CHAT_MODEL_HTTP_TIMEOUT_MS=120000

# 最大耗时（毫秒）
AI_PLAN_TIMEOUT_MS=240000
AI_PLAN_MODEL_TIMEOUT_MS=60000
AI_PLAN_MAX_TOOL_CALLS=10

# tts相关本地模型配置
TTS_PROVIDER=piper
TTS_PIPER_MODEL=/app/runtime/piper/model.onnx
TTS_PIPER_CONFIG=/app/runtime/piper/model.onnx.json
TTS_PIPER_MODEL_URL=https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/zh/zh_CN/huayan/x_low/zh_CN-huayan-x_low.onnx
TTS_PIPER_CONFIG_URL=https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/zh/zh_CN/huayan/x_low/zh_CN-huayan-x_low.onnx.json
TTS_PIPER_MIRROR_HOST=hf-mirror.com

NODE_BASE=docker.m.daocloud.io/library/node:18-bookworm-slim
